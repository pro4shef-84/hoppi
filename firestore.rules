rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Driver Profiles ──────────────────────────────────────────
    // Any visitor can read a driver profile (needed for public booking pages).
    // Only the authenticated owner can create / update / delete their own profile.
    match /drivers/{uid} {
      allow read:             if true;
      allow create, update:   if request.auth != null && request.auth.uid == uid;
      allow delete:           if request.auth != null && request.auth.uid == uid;
    }

    // ── Ride Requests ─────────────────────────────────────────────
    // Anyone (including unauthenticated riders) can submit a booking.
    // Only the driver the request belongs to can read or update it.
    match /rideRequests/{requestId} {
      allow create: if true;
      allow read, update:
        if request.auth != null
        && request.auth.uid == resource.data.driverId;
      allow delete:
        if request.auth != null
        && request.auth.uid == resource.data.driverId;
    }

    // ── Riders ────────────────────────────────────────────────────
    match /riders/{riderId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.driverId;
      allow create:      if request.auth != null
                         && request.auth.uid == request.resource.data.driverId;
    }

  }
}
