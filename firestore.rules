rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Driver Profiles ──────────────────────────────────────────
    // Any visitor can read a driver profile (needed for public booking pages).
    // Only the authenticated owner can create / update / delete their own profile.
    match /drivers/{uid} {
      allow read:             if true;
      allow create, update:   if request.auth != null && request.auth.uid == uid;
      allow delete:           if request.auth != null && request.auth.uid == uid;
    }

    // ── Ride Requests ─────────────────────────────────────────────
    // Anyone (including unauthenticated riders) can submit a booking.
    // Public read is allowed — the document ID acts as a secret tracking key.
    // Only the driver the request belongs to (or assigned team driver) can update it.
    match /rideRequests/{requestId} {
      allow create: if true;
      allow read:   if true;
      allow update:
        if request.auth != null
        && (request.auth.uid == resource.data.driverId
            || request.auth.uid == resource.data.assignedTo);
      allow delete:
        if request.auth != null
        && request.auth.uid == resource.data.driverId;
    }

    // ── Riders ────────────────────────────────────────────────────
    match /riders/{riderId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.driverId;
      allow create:      if request.auth != null
                         && request.auth.uid == request.resource.data.driverId;
    }

    // ── Businesses ────────────────────────────────────────────────
    // Public read so anyone can look up an invite code to join.
    // Only authenticated users can create a business.
    // Only the owner can update / delete.
    match /businesses/{businessId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerUid;
    }

    // ── Route Prices (per-driver route history) ───────────────────
    // Public read so the booking page can show price suggestions.
    // Only the owning driver can write their route data.
    match /routePrices/{driverId}/routes/{routeId} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == driverId;
    }

  }
}
