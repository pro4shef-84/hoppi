rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Driver logos ──────────────────────────────────────────────
    // Only the authenticated owner can upload / overwrite their logo.
    // Anyone can read (so logos show on public booking pages).
    match /logos/{uid}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024          // max 2 MB
                   && request.resource.contentType.matches('image/.*'); // images only
    }

  }
}
